# TaishanPi burn-in runtime configuration template.
# Copy this file to config/tspi-burnin.env and edit local values.

# Public cloud endpoint used by board agents.
BURNIN_SERVER_URL=http://YOUR_SERVER_IP:8080
BURNIN_HTTP_PORT=8080

# Cloud server data and dashboard.
BURNIN_DB=/data/burnin.sqlite3
BURNIN_ARTIFACT_DIR=/data/artifacts
BURNIN_API_TOKEN=change-me
BURNIN_ONLINE_TIMEOUT_SEC=10
BURNIN_DASHBOARD_PATH=/tspi-burnin
BURNIN_PUBLIC_DASHBOARD_PATH=/tspi-burnin-view
BURNIN_METRICS_RETAIN_HOURS=24

# WiFi burn-in schedule and iperf3 settings.
BURNIN_WIFI_EPOCH_SEC=360
BURNIN_WIFI_TCP_SEC=300
BURNIN_WIFI_TCP_PARALLEL=4
BURNIN_WIFI_UDP_BANDWIDTH=0
BURNIN_WIFI_UDP_FLOOD_BANDWIDTH=200M
BURNIN_WIFI_UDP_SMALL_BANDWIDTH=60M
BURNIN_WIFI_UDP_LARGE_BANDWIDTH=120M
BURNIN_WIFI_UDP_FLOOD_RATES=50M,100M,150M,200M
BURNIN_WIFI_UDP_SMALL_RATES=5M,10M,20M,30M,40M,60M
BURNIN_WIFI_UDP_LARGE_RATES=30M,60M,90M,120M,160M,200M
BURNIN_WIFI_UDP_ADAPTIVE_PROBE_SEC=5
BURNIN_WIFI_UDP_ADAPTIVE_MAX_LOSS_PERCENT=5
BURNIN_WIFI_UDP_MIN_SEC=10
BURNIN_IPERF3_PORT=5201

# Bluetooth burn-in settings.
BURNIN_BT_PERIOD_SEC=60
BURNIN_BT_DURATION_SEC=20
BURNIN_BT_L2TEST_DURATION_SEC=25
BURNIN_BT_L2TEST_FRAMES=1000000
BURNIN_BT_L2TEST_BYTES=600
BURNIN_BT_L2TEST_DELAY_MS=20
BURNIN_BT_L2TEST_PSM=

# Board-side agent settings generated into /etc/tspi-burnin/config.toml.
BURNIN_AGENT_BOARD_ID=
BURNIN_AGENT_UPLINK_INTERFACE=end0
BURNIN_AGENT_REQUIRE_UPLINK_INTERFACE=true
BURNIN_AGENT_WIFI_INTERFACE=wlan0
BURNIN_AGENT_BT_CONTROLLER=hci0
BURNIN_AGENT_HEARTBEAT_INTERVAL_SEC=5
BURNIN_AGENT_METRICS_INTERVAL_SEC=5
BURNIN_AGENT_LOG_FLUSH_INTERVAL_SEC=2
BURNIN_AGENT_COMMAND_POLL_INTERVAL_SEC=2
BURNIN_AGENT_COMMAND_WORKERS=2
BURNIN_AGENT_DATA_DIR=/var/lib/tspi-burnin
BURNIN_AGENT_MAX_SPOOL_FILES=20000
BURNIN_AGENT_REQUEST_TIMEOUT_SEC=5
BURNIN_AGENT_ARTIFACT_MAX_BYTES=262144
BURNIN_AGENT_BTMON_CAPTURE_SEC=4
